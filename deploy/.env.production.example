# UMKM Commerce OS Hybrid - production environment example
# Copy to deploy/.env.production on the server and replace every placeholder.
# Do not commit deploy/.env.production.

COMPOSE_PROJECT_NAME=umkm-commerce-os

# Public domains handled by Caddy.
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
ACME_EMAIL=ops@example.com

# Images can point to a registry tag or be built locally by Compose.
API_IMAGE=ghcr.io/your-org/umkm-commerce-os-api:latest
FRONTEND_IMAGE=ghcr.io/your-org/umkm-commerce-os-frontend:latest

# PostgreSQL is private to the Docker network; do not publish its port.
POSTGRES_DB=umkm_os
POSTGRES_USER=umkm_app
POSTGRES_PASSWORD=change-me-use-a-long-random-password

# Backend
APP_ENV=production
APP_NAME=umkm-commerce-os
HTTP_PORT=8080
DATABASE_URL=postgres://umkm_app:change-me-use-a-long-random-password@postgres:5432/umkm_os?sslmode=disable
JWT_SECRET=change-me-use-at-least-32-random-bytes
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
CORS_ALLOWED_ORIGINS=https://app.example.com
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=/app/uploads
STORAGE_PUBLIC_URL=https://api.example.com/uploads
UPLOAD_MAX_BYTES=5242880
OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_BATCH_SIZE=10
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_RETRY_DELAY_SECONDS=30

# Frontend. NEXT_PUBLIC_* values are baked into the frontend image at build time.
NEXT_PUBLIC_APP_NAME=UMKM Commerce OS
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_SITE_URL=https://app.example.com

# Optional health check target used by deploy/scripts/check-health.sh.
API_HEALTH_URL=https://api.example.com/health/ready
