          ]
        },
        {
          "name": "Tracking - Public",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/public/stores/{{storeSlug}}/orders/{{orderNumber}}/tracking?phone={{customerPhone}}"
          }
        }
      ]
