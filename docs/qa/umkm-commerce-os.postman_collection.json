    {
      "name": "Discovery Flow",
      "item": [
        { "name": "Discovery - Home", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/public/discovery/home" } },
        { "name": "Discovery - Stores", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/public/discovery/stores?city=Makassar&limit=20" } },
        { "name": "Discovery - Products", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/public/discovery/products?search=bouquet&limit=20" } },
        { "name": "Discovery - Search", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/public/discovery/search?q=bouquet&type=all" } }
      ]
    },
    {
      "name": "Admin Flow",
      "item": [
        {
          "name": "Admin Auth - Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["const body = pm.response.json();", "if (body?.data?.access_token) pm.collectionVariables.set('adminAccessToken', body.data.access_token);"] }
            }
          ]
        },
        {
          "name": "Admin - Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/me"
          }
        },
        {
          "name": "Admin - List Tenants",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/tenants?limit=20"
          }
        },
        {
          "name": "Admin - List Plans",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/plans"
          }
        },
        {
          "name": "Admin - Suspend Tenant",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"suspended\",\n  \"reason\": \"QA demo suspend\"\n}" },
            "url": "{{baseUrl}}/api/v1/admin/tenants/{{tenantId}}/status"
          }
        },
        {
          "name": "Admin - Activate Tenant",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"active\",\n  \"reason\": \"QA demo activate\"\n}" },
            "url": "{{baseUrl}}/api/v1/admin/tenants/{{tenantId}}/status"
          }
        },
        {
          "name": "Admin - Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/audit-logs?limit=20"
          }
        }
      ]
    }
  ]
}
